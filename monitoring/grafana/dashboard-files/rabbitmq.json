{
  "title": "RabbitMQ",
  "uid": "rabbitmq",
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Status",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rabbitmq_up",
          "legendFormat": "up"
        }
      ]
    },
    {
      "id": 2,
      "title": "Total Messages in Queues",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rabbitmq_queue_messages)",
          "legendFormat": "messages"
        }
      ]
    },
    {
      "id": 3,
      "title": "Unacknowledged",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rabbitmq_queue_messages_unacknowledged)",
          "legendFormat": "unacked"
        }
      ]
    },
    {
      "id": 4,
      "title": "Connections",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rabbitmq_connections",
          "legendFormat": "connections"
        }
      ]
    },
    {
      "id": 5,
      "title": "Queue Depth by Queue",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rabbitmq_queue_messages",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Ready vs Unacknowledged",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rabbitmq_queue_messages_ready)",
          "legendFormat": "ready"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rabbitmq_queue_messages_unacknowledged)",
          "legendFormat": "unacknowledged"
        }
      ]
    },
    {
      "id": 7,
      "title": "Publish Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(rabbitmq_queue_messages_published_total[1m])",
          "legendFormat": "{{queue}} publish/s"
        }
      ]
    },
    {
      "id": 8,
      "title": "Deliver Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(rabbitmq_queue_messages_delivered_total[1m])",
          "legendFormat": "{{queue}} deliver/s"
        }
      ]
    }
  ]
}
