{
  "title": "PostgreSQL",
  "uid": "postgres",
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Status",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pg_up",
          "legendFormat": "up"
        }
      ]
    },
    {
      "id": 2,
      "title": "Active Connections",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(pg_stat_activity_count{state=\"active\"})",
          "legendFormat": "active"
        }
      ]
    },
    {
      "id": 3,
      "title": "Cache Hit Ratio",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(pg_stat_database_blks_hit) / (sum(pg_stat_database_blks_hit) + sum(pg_stat_database_blks_read))",
          "legendFormat": "hit ratio"
        }
      ]
    },
    {
      "id": 4,
      "title": "Active Locks",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(pg_locks_count)",
          "legendFormat": "locks"
        }
      ]
    },
    {
      "id": 5,
      "title": "Connections by State",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "pg_stat_activity_count",
          "legendFormat": "{{state}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Row Operations Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(pg_stat_database_tup_inserted[1m]))",
          "legendFormat": "inserted"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(pg_stat_database_tup_updated[1m]))",
          "legendFormat": "updated"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(pg_stat_database_tup_deleted[1m]))",
          "legendFormat": "deleted"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(pg_stat_database_tup_fetched[1m]))",
          "legendFormat": "fetched"
        }
      ]
    },
    {
      "id": 7,
      "title": "Transactions Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(pg_stat_database_xact_commit[1m]))",
          "legendFormat": "commit/s"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(pg_stat_database_xact_rollback[1m]))",
          "legendFormat": "rollback/s"
        }
      ]
    },
    {
      "id": 8,
      "title": "Deadlocks",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(pg_stat_database_deadlocks[1m]))",
          "legendFormat": "deadlocks/s"
        }
      ]
    }
  ]
}
