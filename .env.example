# Database connection string
MODE="development"
DSN=
DATABASE_URL=

# JWT secret token
TOKEN=
# JWT expired time in days
EXPIRED_AT=1

# Stripe tokens
STRIPE_TOKEN=
STRIPE_RETURN_URL=
STRIPE_WEBHOOK_SECRET=

# Redis
REDIS_USER=
REDIS_USER_PASSWORD=
REDIS_CACHE=
REDIS_ADDR=
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_USER=
RABBITMQ_PASSWORD=
RABBITMQ_AMQP=
RABBITMQ_CONSUMERS=

# ClickHouse
CLICKHOUSE_DB=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_ADDR=

# Mailer (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# GeoIP (optional, country detection disabled if unset)
GEOIP_PATH=

# TOTP (2FA)
TOTP_ISSUER=LinkShort
TOTP_PERIOD=30
TOTP_SKEW=5

# Rate limiting (token-bucket)
RATE_LIMIT_ACCOUNT_CAPACITY=100
RATE_LIMIT_ACCOUNT_REFILL_RATE=100
RATE_LIMIT_IP_CAPACITY=100
RATE_LIMIT_IP_REFILL_RATE=100
